@page
@model DermaAI.Pages.Auth.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - VirtualDerm</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 20px;
                background: linear-gradient(160deg, #f0fdf9 0%, #e0f2fe 100%);
                overflow-x: hidden;
            }

            .login-container {
                width: 100%;
                max-width: 1100px;
                background: white;
                border-radius: 28px;
                overflow: hidden;
                display: flex;
                box-shadow: 0 20px 60px rgba(15, 23, 42, 0.10);
                border: 1px solid #e2e8f0;
            }

            /* LEFT SIDE */
            .login-image {
                width: 46%;
                position: relative;
                overflow: hidden;
                min-height: 580px;
            }

                .login-image img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .image-overlay {
                position: absolute;
                inset: 0;
                background: linear-gradient( to bottom, rgba(20, 184, 166, 0.25), rgba(15, 23, 42, 0.45) );
            }

            .image-logo {
                position: absolute;
                top: 28px;
                left: 28px;
                display: flex;
                align-items: center;
                gap: 10px;
                z-index: 10;
            }

            .image-logo-icon {
                width: 40px;
                height: 40px;
                border-radius: 12px;
                background: linear-gradient(135deg, #2dd4bf, #60a5fa);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 1rem;
            }

            .image-logo span {
                color: white;
                font-size: 1.2rem;
                font-weight: 800;
            }

            .image-text {
                position: absolute;
                bottom: 36px;
                left: 32px;
                right: 32px;
                color: white;
                z-index: 10;
            }

                .image-text h2 {
                    font-size: 1.7rem;
                    font-weight: 800;
                    margin-bottom: 10px;
                    line-height: 1.2;
                }

                .image-text p {
                    font-size: 0.9rem;
                    line-height: 1.7;
                    color: rgba(255, 255, 255, 0.88);
                }

            .image-badges {
                position: absolute;
                top: 90px;
                left: 28px;
                z-index: 10;
                display: flex;
                flex-direction: column;
                gap: 10px;
            }

            .img-badge {
                background: rgba(255, 255, 255, 0.18);
                backdrop-filter: blur(8px);
                border: 1px solid rgba(255,255,255,0.3);
                border-radius: 999px;
                padding: 6px 14px;
                color: white;
                font-size: 0.78rem;
                font-weight: 600;
                display: flex;
                align-items: center;
                gap: 7px;
            }

                .img-badge i {
                    color: #2dd4bf;
                }

            /* RIGHT FORM */
            .login-form-section {
                width: 54%;
                padding: 36px 44px;
                display: flex;
                justify-content: center;
                align-items: center;
                background: white;
            }

            .form-wrapper {
                width: 100%;
                max-width: 420px;
            }

            .form-header {
                margin-bottom: 28px;
            }

            .form-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 18px;
            }

            .form-brand-icon {
                width: 38px;
                height: 38px;
                border-radius: 11px;
                background: linear-gradient(135deg, #2dd4bf, #60a5fa);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 0.95rem;
            }

            .form-brand-name {
                font-size: 1.3rem;
                font-weight: 800;
                color: #0f172a;
            }

            .form-title {
                font-size: 1.75rem;
                font-weight: 800;
                color: #0f172a;
                margin-bottom: 6px;
                line-height: 1.1;
            }

            .form-subtitle {
                color: #64748b;
                font-size: 0.88rem;
                line-height: 1.6;
            }

            .form-group {
                margin-bottom: 16px;
            }

                .form-group label {
                    display: block;
                    margin-bottom: 6px;
                    font-weight: 600;
                    color: #0f172a;
                    font-size: 0.85rem;
                }

            .input-box {
                position: relative;
            }

                .input-box i.field-icon {
                    position: absolute;
                    left: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: 0.88rem;
                }

                .input-box .toggle-eye {
                    position: absolute;
                    right: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: 0.88rem;
                    cursor: pointer;
                    z-index: 2;
                }

                    .input-box .toggle-eye:hover {
                        color: #14b8a6;
                    }

            .form-control {
                width: 100%;
                height: 46px;
                border-radius: 12px;
                border: 1.5px solid #e2e8f0;
                padding: 0 42px 0 42px;
                font-size: 0.9rem;
                background: #f8fafc;
                transition: 0.2s;
                color: #0f172a;
            }

                .form-control:focus {
                    border-color: #14b8a6;
                    box-shadow: 0 0 0 3px rgba(20, 184, 166, 0.12);
                    outline: none;
                    background: white;
                }

            .forgot-link {
                text-align: right;
                margin-top: 6px;
            }

                .forgot-link a {
                    font-size: 0.82rem;
                    color: #14b8a6;
                    text-decoration: none;
                    font-weight: 600;
                }

                    .forgot-link a:hover {
                        text-decoration: underline;
                    }

            .login-btn {
                width: 100%;
                height: 48px;
                border: none;
                border-radius: 12px;
                background: linear-gradient(135deg, #2dd4bf, #14b8a6);
                color: white;
                font-size: 0.95rem;
                font-weight: 700;
                margin-top: 8px;
                cursor: pointer;
                transition: 0.25s;
                box-shadow: 0 6px 20px rgba(45, 212, 191, 0.25);
            }

                .login-btn:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 28px rgba(20, 184, 166, 0.3);
                }

            .divider {
                display: flex;
                align-items: center;
                gap: 14px;
                margin: 16px 0;
                color: #94a3b8;
                font-size: 0.82rem;
            }

                .divider::before,
                .divider::after {
                    content: "";
                    flex: 1;
                    height: 1px;
                    background: #e2e8f0;
                }

            .google-btn {
                width: 100%;
                height: 46px;
                border-radius: 12px;
                border: 1.5px solid #e2e8f0;
                background: white;
                font-weight: 600;
                color: #0f172a;
                font-size: 0.9rem;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                transition: 0.2s;
                cursor: pointer;
            }

                .google-btn:hover {
                    background: #f8fafc;
                    border-color: #cbd5e1;
                }

                .google-btn img {
                    width: 20px;
                    height: 20px;
                }

            .bottom-link {
                margin-top: 20px;
                text-align: center;
                color: #64748b;
                font-size: 0.9rem;
            }

                .bottom-link a {
                    color: #14b8a6;
                    text-decoration: none;
                    font-weight: 700;
                }

                    .bottom-link a:hover {
                        text-decoration: underline;
                    }

            .text-danger {
                font-size: 0.78rem;
                color: #dc2626;
                margin-top: 4px;
                display: block;
            }

            @@media (max-width: 1000px) {
                body {
                    overflow-y: auto;
                }

                .login-container {
                    flex-direction: column;
                    height: auto;
                }

                .login-image {
                    width: 100%;
                    min-height: 200px;
                }

                .login-form-section {
                    width: 100%;
                    padding: 32px 24px;
                }

                .form-title {
                    font-size: 1.5rem;
                }
            }

            @@media (max-width: 600px) {
                .image-text h2 {
                    font-size: 1.4rem;
                }

                .login-form-section {
                    padding: 28px 18px;
                }
            }
    </style>
</head>
<body>

    <div class="login-container">

        <!-- LEFT IMAGE -->
        <div class="login-image">
            <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=1400&auto=format&fit=crop"
                 alt="VirtualDerm" />
            <div class="image-overlay"></div>
            <div class="image-text">
                <h2>Welcome Back<br>to VirtualDerm</h2>
                <p>Access your dermatology consultations, appointments, and AI-assisted skin health guidance.</p>
            </div>
        </div>

        <!-- RIGHT FORM -->
        <div class="login-form-section">
            <div class="form-wrapper">

                <div class="form-header">
                    <div class="form-brand">
                        <div class="form-brand-icon">
                            <i class="fa-solid fa-stethoscope"></i>
                        </div>
                        <span class="form-brand-name">VirtualDerm</span>
                    </div>
                    <div class="form-title">Welcome back</div>
                    <div class="form-subtitle">Login to your VirtualDerm account to continue.</div>
                </div>

                <form method="post">

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- EMAIL -->
                    <div class="form-group">
                        <label asp-for="Input.Email">Email Address</label>
                        <div class="input-box">
                            <i class="fa-regular fa-envelope field-icon"></i>
                            <input asp-for="Input.Email" class="form-control"
                                   placeholder="Enter your email address" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- PASSWORD -->
                    <div class="form-group">
                        <label asp-for="Input.Password">Password</label>
                        <div class="input-box">
                            <i class="fa-solid fa-lock field-icon"></i>
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   id="loginPassword"
                                   type="password"
                                   placeholder="Enter your password" />
                            <i class="fa-regular fa-eye toggle-eye"
                               onclick="togglePassword('loginPassword', this)"></i>
                        </div>

                        <span asp-validation-for="Input.Password" class="text-danger"></span>

                        <div class="forgot-link">
                            <a href="/Auth/ForgotPassword">Forgot password?</a>
                        </div>
                    </div>

                    <!-- LOGIN BUTTON -->
                    <button type="submit" class="login-btn">Login</button>

                </form>

                <div class="divider">OR</div>
                <!-- GOOGLE LOGIN -->
                <form method="post" asp-page-handler="ExternalLogin">

    @Html.AntiForgeryToken()

    <button type="submit"
            class="google-btn"
            name="provider"
            value="Google">

        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg" />
        Continue with Google
    </button>
</form>
                  
                <div class="bottom-link">
                    Don't have an account? <a href="/Auth/Register">Sign Up</a>
                </div>

            </div>
        </div>

    </div>

    <script>
            function togglePassword(fieldId, icon) {
                const input = document.getElementById(fieldId);
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }
            }
    </script>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>