@page
@model DermaAI.Pages.Auth.ForgotPasswordModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - VirtualDerm</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI',sans-serif;
            }

            body {
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 20px;
                background: linear-gradient(160deg,#f0fdf9 0%,#e0f2fe 100%);
            }

            .card {
                width: 100%;
                max-width: 460px;
                background: white;
                border-radius: 24px;
                padding: 40px;
                box-shadow: 0 20px 60px rgba(15,23,42,0.10);
                border: 1px solid #e2e8f0;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 24px;
            }

            .brand-icon {
                width: 38px;
                height: 38px;
                border-radius: 11px;
                background: linear-gradient(135deg,#2dd4bf,#60a5fa);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 0.95rem;
            }

            .brand-name {
                font-size: 1.3rem;
                font-weight: 800;
                color: #0f172a;
            }

            .title {
                font-size: 1.6rem;
                font-weight: 800;
                color: #0f172a;
                margin-bottom: 6px;
            }

            .subtitle {
                color: #64748b;
                font-size: 0.88rem;
                margin-bottom: 24px;
                line-height: 1.6;
            }

            .form-label {
                font-weight: 600;
                color: #0f172a;
                font-size: 0.85rem;
                margin-bottom: 6px;
                display: block;
            }

            .input-box {
                position: relative;
                margin-bottom: 16px;
            }

                .input-box i {
                    position: absolute;
                    left: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #94a3b8;
                    font-size: 0.88rem;
                }

            .form-control {
                width: 100%;
                height: 46px;
                border-radius: 12px;
                border: 1.5px solid #e2e8f0;
                padding: 0 14px 0 42px;
                font-size: 0.9rem;
                background: #f8fafc;
                transition: 0.2s;
                color: #0f172a;
            }

                .form-control:focus {
                    border-color: #14b8a6;
                    box-shadow: 0 0 0 3px rgba(20,184,166,0.12);
                    outline: none;
                    background: white;
                }

            .submit-btn {
                width: 100%;
                height: 48px;
                border: none;
                border-radius: 12px;
                background: linear-gradient(135deg,#2dd4bf,#14b8a6);
                color: white;
                font-size: 0.95rem;
                font-weight: 700;
                cursor: pointer;
                transition: 0.25s;
                box-shadow: 0 6px 20px rgba(45,212,191,0.25);
            }

                .submit-btn:hover {
                    transform: translateY(-2px);
                }

            .back-link {
                text-align: center;
                margin-top: 18px;
                color: #64748b;
                font-size: 0.9rem;
            }

                .back-link a {
                    color: #14b8a6;
                    text-decoration: none;
                    font-weight: 700;
                }

            .alert-success {
                background: #dcfce7;
                color: #16a34a;
                padding: 14px 18px;
                border-radius: 12px;
                margin-bottom: 18px;
                font-weight: 600;
                font-size: 0.88rem;
            }

            .text-danger {
                font-size: 0.78rem;
                color: #dc2626;
                margin-top: 4px;
                display: block;
            }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">
            <div class="brand-icon"><i class="fa-solid fa-stethoscope"></i></div>
            <span class="brand-name">VirtualDerm</span>
        </div>

        <div class="title">Forgot Password</div>
        <div class="subtitle">Enter your email and we'll send you a link to reset your password.</div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">
                <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <label class="form-label">Email Address</label>
            <div class="input-box">
                <i class="fa-regular fa-envelope"></i>
                <input asp-for="Input.Email" class="form-control" placeholder="Enter your email address" />
            </div>
            <span asp-validation-for="Input.Email" class="text-danger"></span>

            <button type="submit" class="submit-btn">Send Reset Link</button>
        </form>

        <div class="back-link">
            Remember your password? <a href="/Auth/Login">Back to Login</a>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>