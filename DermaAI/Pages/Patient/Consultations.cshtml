@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model DermaAI.Pages.Patient.ConsultationsModel
@{
    Layout = "~/Pages/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "My Consultations";
}

<style>
    .container {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 28px;
    }

        .page-header h1 {
            font-size: 1.8rem;
            font-weight: 800;
            color: #0f172a;
        }

        .page-header p {
            color: #64748b;
            margin-top: 6px;
        }

    .consultation-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
        margin-bottom: 16px;
    }

    .consult-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        padding-bottom: 16px;
        border-bottom: 1px solid #e2e8f0;
    }

        .consult-header h3 {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .consult-header .date {
            color: #14b8a6;
            font-size: 0.85rem;
            font-weight: 600;
        }

    .consult-body {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .consult-item label {
        font-size: 0.78rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 6px;
        display: block;
    }

    .consult-item p {
        color: #0f172a;
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .consult-item.full {
        grid-column: 1 / -1;
    }

    .followup-badge {
        background: #eff6ff;
        color: #1e40af;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 16px;
            display: block;
        }
</style>

<div class="container">

    <div class="page-header">
        <h1>My Consultations</h1>
        <p>View your past consultation records, diagnoses, and prescriptions.</p>
    </div>

    @if (!Model.Consultations.Any())
    {
        <div class="empty-state">
            <i class="fa-solid fa-file-medical"></i>
            <p>No consultation records yet.</p>
        </div>
    }
    else
    {
        @foreach (var c in Model.Consultations)
        {
            <div class="consultation-card">

                <div class="consult-header">
                    <div>
                        <h3>
                            <i class="fa-solid fa-user-doctor"></i>
                            @c.Appointment?.DoctorId
                        </h3>

                        <div class="date">
                            <i class="fa-solid fa-calendar"></i>
                            @c.CreatedAt.ToString("MMMM dd, yyyy")
                        </div>
                    </div>

                    @if (c.FollowUpDate.HasValue)
                    {
                        <span class="followup-badge">
                            <i class="fa-solid fa-calendar-check"></i>
                            Follow-up: @c.FollowUpDate.Value.ToString("MMM dd, yyyy")
                        </span>
                    }
                </div>

                <div class="consult-body">

                    <div class="consult-item full">
                        <label>Diagnosis</label>
                        <p>@(c.Diagnosis ?? "None")</p>
                    </div>

                    <div class="consult-item full">
                        <label>Doctor Notes</label>
                        <p>@c.DoctorNotes</p>
                    </div>

                    <div class="consult-item">
                        <label>Prescription</label>
                        <p>@(c.Prescription ?? "None")</p>
                    </div>

                </div>

            </div>
        }
    }

</div>