@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model DermaAI.Pages.Patient.AIAssistantModel
@{
    Layout = "~/Pages/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "AI Skin Assistant";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<style>
    .chat-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    }

    .chat-header {
    text-align: center;
    margin-bottom: 24px;
    }

    .chat-header h1 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #0f172a;
    }

    .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #2dd4bf, #60a5fa);
    color: white;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 12px;
    }

    .chat-box {
    background: white;
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    min-height: 500px;
    overflow: hidden;
    }

    .messages {
    flex: 1;
    padding: 24px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-height: 450px;
    }

    .message {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    }

    .message.user {
    flex-direction: row-reverse;
    }

    .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    }

    .avatar.ai {
    background: linear-gradient(135deg, #2dd4bf, #60a5fa);
    color: white;
    }

    .avatar.user {
    background: linear-gradient(135deg, #a78bfa, #7c3aed);
    color: white;
    }

    .bubble {
    max-width: 75%;
    padding: 12px 16px;
    border-radius: 16px;
    font-size: 0.95rem;
    line-height: 1.6;
    }

    .bubble.ai {
    background: #f8fafc;
    border-bottom-left-radius: 4px;
    }

    .bubble.user {
    background: linear-gradient(135deg, #2dd4bf, #14b8a6);
    color: white;
    border-bottom-right-radius: 4px;
    }

    .chat-input {
    padding: 16px;
    border-top: 1px solid #e2e8f0;
    display: flex;
    gap: 12px;
    }

    .chat-input input {
    flex: 1;
    height: 48px;
    border-radius: 12px;
    border: 1.5px solid #e2e8f0;
    padding: 0 16px;
    outline: none;
    }

    .send-btn {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, #2dd4bf, #14b8a6);
    border: none;
    color: white;
    cursor: pointer;
    }

    .suggestions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    padding: 12px 16px;
    }

    .suggestion-btn {
    background: #f0fdf9;
    border: 1px solid #99f6e4;
    color: #0f766e;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.8rem;
    cursor: pointer;
    }

    .typing {
    display: none;
    padding: 0 16px 12px;
    color: #94a3b8;
    font-size: 0.85rem;
    }
</style>

<div class="chat-container">

    <div class="chat-header">
        <div class="ai-badge">
            <i class="fa-solid fa-robot"></i> AI-Powered
        </div>
        <h1>AI Skin Assistant</h1>
    </div>

    <div class="chat-box">

        <div class="messages" id="messages">
            <div class="message">
                <div class="avatar ai"><i class="fa-solid fa-robot"></i></div>
                <div class="bubble ai">
                    Hello! I'm your VirtualDerm AI. How can I help you with your skin today?
                </div>
            </div>
        </div>

        <div class="suggestions">
            <button class="suggestion-btn" onclick="sendSuggestion('Tips for dry skin?')">Dry skin tips</button>
            <button class="suggestion-btn" onclick="sendSuggestion('What is eczema?')">Eczema</button>
        </div>

        <div class="typing" id="typing">
            <i class="fa-solid fa-robot"></i> AI is thinking...
        </div>

        <div class="chat-input">
            <input type="text" id="messageInput"
                   placeholder="Type your skin concern..."
                   onkeypress="if(event.key==='Enter') sendMessage()" />
            <button class="send-btn" onclick="sendMessage()">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </div>

    </div>

</div>

<script>
    async function sendMessage() {
    const input = document.getElementById('messageInput');
    const msg = input.value.trim();
    if (!msg) return;

    input.value = '';
    appendMessage('user', msg);
    await getAIResponse(msg);
    }

    function sendSuggestion(text) {
    document.getElementById('messageInput').value = text;
    sendMessage();
    }

    function appendMessage(role, text) {
    const messages = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = `message ${role}`;

    const content = role === 'ai' ? marked.parse(text) : text;

    div.innerHTML = `
    <div class="avatar ${role}">
    <i class="fa-solid ${role === 'ai' ? 'fa-robot' : 'fa-user'}"></i>
    </div>
    <div class="bubble ${role}">${content}</div>
    `;

    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
    }

    async function getAIResponse(userMsg) {
    const typing = document.getElementById('typing');
    typing.style.display = 'block';

    try {
    const response = await fetch('/Patient/AIAssistant?handler=Chat', {
    method: 'POST',
    headers: {
    'Content-Type': 'application/json',
    'X-Requested-With': 'XMLHttpRequest'
    },
    body: JSON.stringify({ Message: userMsg })
    });

    const data = await response.json();
    typing.style.display = 'none';
    appendMessage('ai', data.reply);

    } catch (err) {
    typing.style.display = 'none';
    appendMessage('ai', 'Error connecting to server.');
    }
    }
</script>