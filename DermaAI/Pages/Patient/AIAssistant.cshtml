@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model DermaAI.Pages.Patient.AIAssistantModel
@{
    Layout = null;
    ViewData["Title"] = "AI Skin Assistant";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Skin Assistant - VirtualDerm</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
        }

        body {
        background: linear-gradient(160deg, #f0fdf9 0%, #e0f2fe 100%);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        }

        .navbar {
        background: white;
        padding: 16px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        }

        .navbar-brand {
        font-size: 1.3rem;
        font-weight: 800;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: 10px;
        }

        .navbar-brand-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #2dd4bf, #60a5fa);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        }

        .navbar-links {
        display: flex;
        gap: 24px;
        align-items: center;
        }

        .navbar-links a {
        text-decoration: none;
        color: #64748b;
        font-weight: 500;
        font-size: 0.9rem;
        }

        .navbar-links a.active {
        color: #14b8a6;
        }

        .logout-btn {
        background: #f1f5f9;
        border: none;
        padding: 8px 18px;
        border-radius: 8px;
        color: #0f172a;
        font-weight: 600;
        cursor: pointer;
        }

        .chat-container {
        max-width: 800px;
        margin: 30px auto;
        padding: 0 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
        width: 100%;
        }

        .chat-header {
        text-align: center;
        margin-bottom: 24px;
        }

        .chat-header h1 {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0f172a;
        }

        .ai-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #2dd4bf, #60a5fa);
        color: white;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 600;
        margin-bottom: 12px;
        }

        .chat-box {
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 450px;
        overflow: hidden;
        }

        .messages {
        flex: 1;
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
        max-height: 450px;
        }

        .message {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        }

        .message.user {
        flex-direction: row-reverse;
        }

        .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        }

        .avatar.ai {
        background: linear-gradient(135deg, #2dd4bf, #60a5fa);
        color: white;
        }

        .avatar.user {
        background: linear-gradient(135deg, #a78bfa, #7c3aed);
        color: white;
        }

        .bubble {
        max-width: 75%;
        padding: 12px 16px;
        border-radius: 16px;
        font-size: 0.95rem;
        line-height: 1.6;
        }

        .bubble.ai {
        background: #f8fafc;
        color: #0f172a;
        border-bottom-left-radius: 4px;
        }

        .bubble.user {
        background: linear-gradient(135deg, #2dd4bf, #14b8a6);
        color: white;
        border-bottom-right-radius: 4px;
        }

        /* Markdown Styling Fixes */
        .bubble.ai ul, .bubble.ai ol {
        padding-left: 20px;
        margin: 8px 0;
        }

        .bubble.ai li {
        margin-bottom: 4px;
        }

        .bubble.ai p {
        margin-bottom: 8px;
        }

        .bubble.ai p:last-child {
        margin-bottom: 0;
        }

        .chat-input {
        padding: 16px 24px;
        border-top: 1px solid #e2e8f0;
        display: flex;
        gap: 12px;
        align-items: center;
        background: #fff;
        }

        .chat-input input {
        flex: 1;
        height: 48px;
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        padding: 0 16px;
        outline: none;
        }

        .send-btn {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg, #2dd4bf, #14b8a6);
        border: none;
        color: white;
        cursor: pointer;
        }

        .disclaimer {
        font-size: 0.75rem;
        color: #94a3b8;
        text-align: center;
        padding: 10px;
        }

        .typing {
        display: none;
        align-items: center;
        gap: 8px;
        padding: 0 24px 12px;
        color: #94a3b8;
        font-size: 0.85rem;
        }

        .suggestions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        padding: 0 24px 16px;
        }

        .suggestion-btn {
        background: #f0fdf9;
        border: 1px solid #99f6e4;
        color: #0f766e;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        cursor: pointer;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-brand"><div class="navbar-brand-icon"><i class="fa-solid fa-stethoscope"></i></div> VirtualDerm</div>
        <div class="navbar-links">
            <a href="/Patient/Dashboard">Dashboard</a>
            <a href="/Patient/AIAssistant" class="active">AI Assistant</a>
            <button type="button" class="logout-btn" onclick="document.getElementById('logoutModal').style.display='flex'">Logout</button>

            <!-- Logout Modal -->
            <div id="logoutModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
                <div style="background:white; border-radius:20px; padding:32px; max-width:400px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
                    <div style="width:60px; height:60px; background:#f0fdf9; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
                        <i class="fa-solid fa-right-from-bracket" style="color:#14b8a6; font-size:1.5rem;"></i>
                    </div>
                    <h3 style="font-size:1.2rem; font-weight:700; color:#0f172a; margin-bottom:8px;">Logout</h3>
                    <p style="color:#64748b; font-size:0.9rem; margin-bottom:24px;">Are you sure you want to logout from VirtualDerm?</p>
                    <div style="display:flex; gap:12px;">
                        <button onclick="document.getElementById('logoutModal').style.display='none'" style="flex:1; height:44px; border-radius:10px; border:1.5px solid #e2e8f0; background:white; font-weight:600; cursor:pointer; color:#64748b;">Cancel</button>
                        <form method="post" asp-page="/Auth/Logout" style="flex:1; margin:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="width:100%; height:44px; border-radius:10px; border:none; background:linear-gradient(135deg, #2dd4bf, #14b8a6); color:white; font-weight:700; cursor:pointer;">Yes, Logout</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="chat-container">
        <div class="chat-header">
            <div class="ai-badge"><i class="fa-solid fa-robot"></i> AI-Powered</div>
            <h1>AI Skin Assistant</h1>
        </div>

        <div class="chat-box">
            <div class="messages" id="messages">
                <div class="message">
                    <div class="avatar ai"><i class="fa-solid fa-robot"></i></div>
                    <div class="bubble ai">Hello! I'm your VirtualDerm AI. How can I help you with your skin today?</div>
                </div>
            </div>

            <div class="suggestions">
                <button class="suggestion-btn" onclick="sendSuggestion('Tips for dry skin?')">Tips for dry skin?</button>
                <button class="suggestion-btn" onclick="sendSuggestion('What is Eczema?')">What is Eczema?</button>
            </div>

            <div class="typing" id="typing">
                <div class="avatar ai"><i class="fa-solid fa-robot"></i></div>
                <span>AI is thinking...</span>
            </div>

            <div class="chat-input">
                <input type="text" id="messageInput" placeholder="Type your skin concern..." onkeypress="if(event.key==='Enter') sendMessage()" />
                <button class="send-btn" onclick="sendMessage()"><i class="fa-solid fa-paper-plane"></i></button>
            </div>
            <div class="disclaimer">
                AI responses are for information only and not a medical diagnosis. Consult a doctor for serious concerns.
            </div>
        </div>
    </div>

    <script>
        async function sendMessage() {
        const input = document.getElementById('messageInput');
        const msg = input.value.trim();
        if (!msg) return;
        input.value = '';
        appendMessage('user', msg);
        await getAIResponse(msg);
        }

        function sendSuggestion(text) {
        document.getElementById('messageInput').value = text;
        sendMessage();
        }

        function appendMessage(role, text) {
        const messages = document.getElementById('messages');
        const div = document.createElement('div');
        div.className = `message ${role}`;

        // Use marked.parse for AI responses to support bullets
        const content = role === 'ai' ? marked.parse(text) : text;

        div.innerHTML = `
        <div class="avatar ${role}">${role === 'ai' ? '<i class="fa-solid fa-robot"></i>' : '<i class="fa-solid fa-user"></i>'}</div>
        <div class="bubble ${role}">${content}</div>`;
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
        }

        async function getAIResponse(userMsg) {
        const typing = document.getElementById('typing');
        typing.style.display = 'flex';
        try {
        const response = await fetch('/Patient/AIAssistant?handler=Chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ Message: userMsg })
        });
        const data = await response.json();
        typing.style.display = 'none';
        appendMessage('ai', data.reply);
        } catch (err) {
        typing.style.display = 'none';
        appendMessage('ai', 'Error connecting to server.');
        }
        }
    </script>
</body>
</html>