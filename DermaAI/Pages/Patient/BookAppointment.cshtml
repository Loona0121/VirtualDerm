@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model DermaAI.Pages.Patient.BookAppointmentModel

@{
    Layout = "_PatientLayout";
    ViewData["Title"] = "Book Appointment";
}

<style>
    .appointment-page {
        max-width: 850px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 28px;
    }

        .page-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
        }

        .page-header p {
            color: #64748b;
            font-size: 0.95rem;
            margin: 0;
        }

    .appointment-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        border: 1px solid #eef2f5;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title i {
            color: #2ec4b6;
        }

    .form-group {
        margin-bottom: 22px;
    }

    .form-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 10px;
        display: block;
        font-size: 0.92rem;
    }

    .input-wrapper {
        position: relative;
    }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.95rem;
        }

    .custom-input,
    .custom-select,
    .custom-textarea {
        width: 100%;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        background-color: #f8fafc;
        color: #0f172a;
        transition: all 0.2s ease;
        font-size: 0.95rem;
    }

    .custom-input,
    .custom-select {
        height: 52px;
        padding: 0 16px 0 46px;
    }

    .custom-textarea {
        min-height: 130px;
        resize: vertical;
        padding: 16px 16px 16px 46px;
    }

        .custom-input:focus,
        .custom-select:focus,
        .custom-textarea:focus {
            outline: none;
            border-color: #2ec4b6;
            background: white;
            box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.12);
        }

    .textarea-icon {
        top: 20px !important;
        transform: none !important;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .submit-btn {
        border: none;
        background: #2ec4b6;
        color: white;
        font-weight: 600;
        height: 52px;
        width: 100%;
        border-radius: 14px;
        transition: all 0.2s ease;
        margin-top: 10px;
        font-size: 0.95rem;
    }

        .submit-btn:hover {
            background: #26b3a6;
            transform: translateY(-1px);
            box-shadow: 0 10px 24px rgba(46, 196, 182, 0.25);
        }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 24px;
        transition: 0.2s;
    }

        .back-btn:hover {
            color: #2ec4b6;
        }

    .alert-success {
        background: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #065f46;
        padding: 14px 18px;
        border-radius: 14px;
        margin-bottom: 24px;
        font-size: 0.92rem;
    }

    .text-danger {
        font-size: 0.8rem;
        margin-top: 6px;
        display: block;
    }

    @@media (max-width: 768px) {
        .appointment-card {
            padding: 24px;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .page-header h1 {
            font-size: 1.6rem;
        }
    }
</style>

<div class="appointment-page">

    <a href="/Patient/Appointments" class="back-btn">
        <i class="fa-solid fa-arrow-left"></i>
        Back to Appointments
    </a>

    <div class="page-header">
        <h1>Book Appointment</h1>
        <p>Schedule a consultation with one of our dermatologists.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            <i class="fa-solid fa-circle-check"></i>
            @TempData["Success"]
        </div>
    }

    <div class="appointment-card">

        <div class="section-title">
            <i class="fa-solid fa-calendar-check"></i>
            Appointment Details
        </div>

        <form method="post">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-group">
                <label class="form-label">Select Dermatologist</label>

                <div class="input-wrapper">
                    <i class="fa-solid fa-user-doctor"></i>

                    <select asp-for="Input.DoctorId" class="form-control">
                        <option value="0">-- Select Doctor --</option>

                        @foreach (var doctor in Model.Doctors)
                        {
                            <option value="@doctor.Id">@doctor.FullName</option>
                        }
                    </select>
                </div>

                <span asp-validation-for="Input.DoctorId" class="text-danger"></span>
            </div>

            <div class="form-grid">

                <div class="form-group">
                    <label class="form-label">Appointment Date</label>

                    <div class="input-wrapper">
                        <i class="fa-solid fa-calendar"></i>

                        <input asp-for="Input.ScheduledDate"
                               type="date"
                               class="custom-input"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    <span asp-validation-for="Input.ScheduledDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Time Slot</label>

                    <div class="input-wrapper">
                        <i class="fa-solid fa-clock"></i>

                        <select asp-for="Input.TimeSlot" class="custom-select">
                            <option value="">-- Select time --</option>
                            <option>8:00 AM</option>
                            <option>9:00 AM</option>
                            <option>10:00 AM</option>
                            <option>11:00 AM</option>
                            <option>1:00 PM</option>
                            <option>2:00 PM</option>
                            <option>3:00 PM</option>
                            <option>4:00 PM</option>
                        </select>
                    </div>

                    <span asp-validation-for="Input.TimeSlot" class="text-danger"></span>
                </div>

            </div>

            <div class="form-group">
                <label class="form-label">Skin Concern / Notes</label>

                <div class="input-wrapper">
                    <i class="fa-solid fa-notes-medical textarea-icon"></i>

                    <textarea asp-for="Input.Notes"
                              class="custom-textarea"
                              placeholder="Describe your skin concern or symptoms..."></textarea>
                </div>

                <span asp-validation-for="Input.Notes" class="text-danger"></span>
            </div>

            <button type="submit" class="submit-btn">
                <i class="fa-solid fa-calendar-check"></i>
                Confirm Appointment
            </button>

        </form>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />