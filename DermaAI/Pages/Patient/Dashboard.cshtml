@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model DermaAI.Pages.Patient.DashboardModel
@{
    Layout = null;
    ViewData["Title"] = "Patient Dashboard";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Patient Dashboard - VirtualDerm</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                background: linear-gradient(160deg, #f0fdf9 0%, #e0f2fe 100%);
                min-height: 100vh;
            }

            .navbar {
                background: white;
                padding: 16px 32px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            }

            .navbar-brand {
                font-size: 1.3rem;
                font-weight: 800;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .navbar-brand-icon {
                width: 36px;
                height: 36px;
                border-radius: 10px;
                background: linear-gradient(135deg, #2dd4bf, #60a5fa);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
            }

            .navbar-links {
                display: flex;
                gap: 24px;
                align-items: center;
            }

                .navbar-links a {
                    text-decoration: none;
                    color: #64748b;
                    font-weight: 500;
                    font-size: 0.9rem;
                }

                    .navbar-links a:hover {
                        color: #14b8a6;
                    }

            .logout-btn {
                background: #f1f5f9;
                border: none;
                padding: 8px 18px;
                border-radius: 8px;
                color: #0f172a;
                font-weight: 600;
                cursor: pointer;
                font-size: 0.88rem;
            }

                .logout-btn:hover {
                    background: #e2e8f0;
                }

            .container {
                max-width: 1100px;
                margin: 0 auto;
                padding: 36px 24px;
            }

            .welcome {
                margin-bottom: 32px;
            }

                .welcome h1 {
                    font-size: 2rem;
                    font-weight: 800;
                    color: #0f172a;
                }

                .welcome p {
                    color: #64748b;
                    margin-top: 6px;
                }

            .stats-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 20px;
                margin-bottom: 32px;
            }

            .stat-card {
                background: white;
                border-radius: 16px;
                padding: 24px;
                box-shadow: 0 4px 16px rgba(0,0,0,0.06);
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .stat-icon {
                width: 50px;
                height: 50px;
                border-radius: 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.3rem;
                color: white;
            }

                .stat-icon.teal {
                    background: linear-gradient(135deg, #2dd4bf, #14b8a6);
                }

                .stat-icon.blue {
                    background: linear-gradient(135deg, #60a5fa, #3b82f6);
                }

                .stat-icon.purple {
                    background: linear-gradient(135deg, #a78bfa, #7c3aed);
                }

            .stat-info h3 {
                font-size: 1.6rem;
                font-weight: 800;
                color: #0f172a;
            }

            .stat-info p {
                color: #64748b;
                font-size: 0.85rem;
            }

            .quick-access h2 {
                font-size: 1.2rem;
                font-weight: 700;
                color: #0f172a;
                margin-bottom: 16px;
            }

            .quick-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 16px;
            }

            .quick-card {
                background: white;
                border-radius: 16px;
                padding: 24px;
                box-shadow: 0 4px 16px rgba(0,0,0,0.06);
                text-decoration: none;
                color: #0f172a;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 12px;
                transition: 0.2s;
                text-align: center;
            }

                .quick-card:hover {
                    transform: translateY(-4px);
                    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
                }

                .quick-card i {
                    font-size: 1.8rem;
                    color: #14b8a6;
                }

                .quick-card span {
                    font-weight: 600;
                    font-size: 0.95rem;
                }

                .quick-card small {
                    color: #64748b;
                    font-size: 0.8rem;
                }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-brand">
            <div class="navbar-brand-icon"><i class="fa-solid fa-stethoscope"></i></div>
            VirtualDerm
        </div>
        <div class="navbar-links">
            <a href="/Patient/Dashboard">Dashboard</a>
            <a href="/Patient/Appointments">Appointments</a>
            <a href="/Patient/Consultations">Consultations</a>
            <a href="/Patient/AIAssistant">AI Assistant</a>
            <a href="/Patient/Profile">Profile</a>
            <button type="button" class="logout-btn" onclick="document.getElementById('logoutModal').style.display='flex'">Logout</button>

            <!-- Logout Modal -->
            <div id="logoutModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
                <div style="background:white; border-radius:20px; padding:32px; max-width:400px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
                    <div style="width:60px; height:60px; background:#f0fdf9; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
                        <i class="fa-solid fa-right-from-bracket" style="color:#14b8a6; font-size:1.5rem;"></i>
                    </div>
                    <h3 style="font-size:1.2rem; font-weight:700; color:#0f172a; margin-bottom:8px;">Logout</h3>
                    <p style="color:#64748b; font-size:0.9rem; margin-bottom:24px;">Are you sure you want to logout from VirtualDerm?</p>
                    <div style="display:flex; gap:12px;">
                        <button onclick="document.getElementById('logoutModal').style.display='none'" style="flex:1; height:44px; border-radius:10px; border:1.5px solid #e2e8f0; background:white; font-weight:600; cursor:pointer; color:#64748b;">Cancel</button>
                        <form method="post" asp-page="/Auth/Logout" style="flex:1; margin:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="width:100%; height:44px; border-radius:10px; border:none; background:linear-gradient(135deg, #2dd4bf, #14b8a6); color:white; font-weight:700; cursor:pointer;">Yes, Logout</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="welcome">
            <h1>Welcome back, @Model.PatientName! 👋</h1>
            <p>Here's your health summary for today.</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon teal"><i class="fa-solid fa-calendar-check"></i></div>
                <div class="stat-info">
                    <h3>@Model.UpcomingAppointments</h3>
                    <p>Upcoming Appointments</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fa-solid fa-notes-medical"></i></div>
                <div class="stat-info">
                    <h3>@Model.PastConsultations</h3>
                    <p>Past Consultations</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple"><i class="fa-solid fa-clock-rotate-left"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalAppointments</h3>
                    <p>Total Appointments</p>
                </div>
            </div>
        </div>

        <div class="quick-access">
            <h2>Quick Access</h2>
            <div class="quick-grid">
                <a href="/Patient/BookAppointment" class="quick-card">
                    <i class="fa-solid fa-calendar-plus"></i>
                    <span>Book Appointment</span>
                    <small>Schedule a new visit</small>
                </a>
                <a href="/Patient/Appointments" class="quick-card">
                    <i class="fa-solid fa-calendar-days"></i>
                    <span>My Appointments</span>
                    <small>View all appointments</small>
                </a>
                <a href="/Patient/Consultations" class="quick-card">
                    <i class="fa-solid fa-file-medical"></i>
                    <span>Consultations</span>
                    <small>View past records</small>
                </a>
                <a href="/Patient/AIAssistant" class="quick-card">
                    <i class="fa-solid fa-robot"></i>
                    <span>AI Skin Assistant</span>
                    <small>Get AI-powered advice</small>
                </a>
                <a href="/Patient/Profile" class="quick-card">
                    <i class="fa-solid fa-user"></i>
                    <span>My Profile</span>
                    <small>View and edit info</small>
                </a>
            </div>
        </div>
    </div>
</body>
</html>