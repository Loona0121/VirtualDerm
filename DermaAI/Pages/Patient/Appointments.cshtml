@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model DermaAI.Pages.Patient.AppointmentsModel
@{
    Layout = null;
    ViewData["Title"] = "My Appointments";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Appointments - VirtualDerm</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                background: linear-gradient(160deg, #f0fdf9 0%, #e0f2fe 100%);
                min-height: 100vh;
            }

            .navbar {
                background: white;
                padding: 16px 32px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            }

            .navbar-brand {
                font-size: 1.3rem;
                font-weight: 800;
                color: #0f172a;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .navbar-brand-icon {
                width: 36px;
                height: 36px;
                border-radius: 10px;
                background: linear-gradient(135deg, #2dd4bf, #60a5fa);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
            }

            .navbar-links {
                display: flex;
                gap: 24px;
                align-items: center;
            }

                .navbar-links a {
                    text-decoration: none;
                    color: #64748b;
                    font-weight: 500;
                    font-size: 0.9rem;
                }

                    .navbar-links a:hover, .navbar-links a.active {
                        color: #14b8a6;
                    }

            .logout-btn {
                background: #f1f5f9;
                border: none;
                padding: 8px 18px;
                border-radius: 8px;
                color: #0f172a;
                font-weight: 600;
                cursor: pointer;
                font-size: 0.88rem;
            }

            .container {
                max-width: 900px;
                margin: 40px auto;
                padding: 0 24px;
            }

            .page-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 28px;
            }

                .page-header h1 {
                    font-size: 1.8rem;
                    font-weight: 800;
                    color: #0f172a;
                }

            .book-btn {
                background: linear-gradient(135deg, #2dd4bf, #14b8a6);
                color: white;
                border: none;
                padding: 10px 22px;
                border-radius: 10px;
                font-weight: 600;
                font-size: 0.9rem;
                cursor: pointer;
                text-decoration: none;
            }

            .tabs {
                display: flex;
                gap: 8px;
                margin-bottom: 24px;
            }

            .tab {
                padding: 8px 20px;
                border-radius: 20px;
                font-weight: 600;
                font-size: 0.88rem;
                cursor: pointer;
                border: none;
                background: white;
                color: #64748b;
            }

                .tab.active {
                    background: linear-gradient(135deg, #2dd4bf, #14b8a6);
                    color: white;
                }

            .appointment-card {
                background: white;
                border-radius: 16px;
                padding: 22px 24px;
                box-shadow: 0 4px 16px rgba(0,0,0,0.06);
                margin-bottom: 14px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .appt-info h3 {
                font-size: 1rem;
                font-weight: 700;
                color: #0f172a;
                margin-bottom: 4px;
            }

            .appt-info p {
                color: #64748b;
                font-size: 0.85rem;
            }

            .appt-info .date {
                color: #14b8a6;
                font-weight: 600;
                font-size: 0.88rem;
                margin-top: 4px;
            }

            .status-badge {
                padding: 4px 14px;
                border-radius: 20px;
                font-size: 0.78rem;
                font-weight: 700;
            }

            .status-Pending {
                background: #fef9c3;
                color: #854d0e;
            }

            .status-Confirmed {
                background: #dcfce7;
                color: #166534;
            }

            .status-Cancelled {
                background: #fee2e2;
                color: #991b1b;
            }

            .appt-actions {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .cancel-btn {
                background: #fee2e2;
                color: #dc2626;
                border: none;
                padding: 7px 16px;
                border-radius: 8px;
                font-weight: 600;
                font-size: 0.82rem;
                cursor: pointer;
            }

                .cancel-btn:hover {
                    background: #fecaca;
                }

            .empty-state {
                text-align: center;
                padding: 60px 20px;
                color: #94a3b8;
            }

                .empty-state i {
                    font-size: 3rem;
                    margin-bottom: 16px;
                }

                .empty-state p {
                    font-size: 1rem;
                }

            .alert-success {
                background: #f0fdf4;
                border: 1px solid #86efac;
                color: #166534;
                padding: 14px 18px;
                border-radius: 12px;
                margin-bottom: 20px;
            }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-brand">
            <div class="navbar-brand-icon"><i class="fa-solid fa-stethoscope"></i></div>
            VirtualDerm
        </div>
        <div class="navbar-links">
            <a href="/Patient/Dashboard">Dashboard</a>
            <a href="/Patient/Appointments" class="active">Appointments</a>
            <a href="/Patient/Consultations">Consultations</a>
            <a href="/Patient/AIAssistant">AI Assistant</a>
            <a href="/Patient/Profile">Profile</a>
            <button type="button" class="logout-btn" onclick="document.getElementById('logoutModal').style.display='flex'">Logout</button>

            <!-- Logout Modal -->
            <div id="logoutModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
                <div style="background:white; border-radius:20px; padding:32px; max-width:400px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
                    <div style="width:60px; height:60px; background:#f0fdf9; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
                        <i class="fa-solid fa-right-from-bracket" style="color:#14b8a6; font-size:1.5rem;"></i>
                    </div>
                    <h3 style="font-size:1.2rem; font-weight:700; color:#0f172a; margin-bottom:8px;">Logout</h3>
                    <p style="color:#64748b; font-size:0.9rem; margin-bottom:24px;">Are you sure you want to logout from VirtualDerm?</p>
                    <div style="display:flex; gap:12px;">
                        <button onclick="document.getElementById('logoutModal').style.display='none'" style="flex:1; height:44px; border-radius:10px; border:1.5px solid #e2e8f0; background:white; font-weight:600; cursor:pointer; color:#64748b;">Cancel</button>
                        <form method="post" asp-page="/Auth/Logout" style="flex:1; margin:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="width:100%; height:44px; border-radius:10px; border:none; background:linear-gradient(135deg, #2dd4bf, #14b8a6); color:white; font-weight:700; cursor:pointer;">Yes, Logout</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["Success"]</div>
        }

        <div class="page-header">
            <h1>My Appointments</h1>
            <a href="/Patient/BookAppointment" class="book-btn"><i class="fa-solid fa-plus"></i> Book New</a>
        </div>

        <div class="tabs">
            <button class="tab active" onclick="showTab('upcoming')">Upcoming</button>
            <button class="tab" onclick="showTab('past')">Past</button>
        </div>

        <div id="upcoming">
            @if (!Model.UpcomingAppointments.Any())
            {
                <div class="empty-state">
                    <i class="fa-solid fa-calendar-xmark"></i>
                    <p>No upcoming appointments.</p>
                </div>
            }
            else
            {
                @foreach (var appt in Model.UpcomingAppointments)
                {
                    <div class="appointment-card">
                        <div class="appt-info">
                            <h3><i class="fa-solid fa-user-doctor"></i> @appt.DoctorName</h3>
                            <p class="date"><i class="fa-solid fa-calendar"></i> @appt.ScheduledDate.ToString("MMMM dd, yyyy")</p>
                            <p>@appt.Notes</p>
                        </div>
                        <div class="appt-actions">
                            <span class="status-badge status-@appt.Status">@appt.Status</span>
                            @if (appt.Status != "Cancelled")
                            {
                                <form method="post" asp-page-handler="Cancel">
                                    <input type="hidden" name="appointmentId" value="@appt.Id" />
                                    <button type="submit" class="cancel-btn" onclick="return confirm('Cancel this appointment?')">Cancel</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <div id="past" style="display:none">
            @if (!Model.PastAppointments.Any())
            {
                <div class="empty-state">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <p>No past appointments.</p>
                </div>
            }
            else
            {
                @foreach (var appt in Model.PastAppointments)
                {
                    <div class="appointment-card">
                        <div class="appt-info">
                            <h3><i class="fa-solid fa-user-doctor"></i> @appt.DoctorName</h3>
                            <p class="date"><i class="fa-solid fa-calendar"></i> @appt.ScheduledDate.ToString("MMMM dd, yyyy")</p>
                            <p>@appt.Notes</p>
                        </div>
                        <div class="appt-actions">
                            <span class="status-badge status-@appt.Status">@appt.Status</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <script>
            function showTab(tab) {
                document.getElementById('upcoming').style.display = tab === 'upcoming' ? 'block' : 'none';
                document.getElementById('past').style.display = tab === 'past' ? 'block' : 'none';
                document.querySelectorAll('.tab').forEach((t, i) => {
                    t.classList.toggle('active', (tab === 'upcoming' && i === 0) || (tab === 'past' && i === 1));
                });
            }
    </script>
</body>
</html>