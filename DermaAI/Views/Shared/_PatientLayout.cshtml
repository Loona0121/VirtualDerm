@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VirtualDerm</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                background-color: #f4f9f9;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                color: #2c3e50;
                margin: 0;
                display: flex;
                min-height: 100vh;
            }

            /* Sidebar Container */
            .sidebar-wrapper {
                width: 260px;
                background-color: #ffffff;
                border-right: 1px solid #eef2f5;
                display: flex;
                flex-direction: column;
                position: fixed;
                top: 0;
                bottom: 0;
                left: 0;
                z-index: 100;
                padding: 24px;
            }

            /* Brand Area */
            .sidebar-brand-container {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
                margin-bottom: 40px;
            }

            .brand-logo-icon {
                background-color: #2ec4b6;
                color: white;
                width: 42px;
                height: 42px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.4rem;
            }

            .brand-text {
                font-weight: 700;
                color: #0f172a;
                font-size: 1.5rem;
                letter-spacing: -0.5px;
            }

            /* Nav Layout Groupings */
            .menu-section-label {
                font-size: 0.75rem;
                font-weight: 700;
                text-transform: uppercase;
                color: #94a3b8;
                letter-spacing: 0.5px;
                margin-bottom: 12px;
                margin-top: 24px;
            }

            .sidebar-nav-links {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            /* Sidebar Individual Link Buttons */
            .sidebar-nav-link {
                display: flex;
                align-items: center;
                gap: 14px;
                color: #64748b;
                font-weight: 600;
                text-decoration: none;
                padding: 12px 16px;
                border-radius: 14px;
                font-size: 0.95rem;
                transition: all 0.2s ease;
            }

                .sidebar-nav-link i {
                    font-size: 1.1rem;
                    width: 20px;
                    text-align: center;
                }

                .sidebar-nav-link:hover {
                    background-color: #f8fafc;
                    color: #2ec4b6;
                }

                .sidebar-nav-link.active {
                    background-color: #2ec4b6;
                    color: white;
                    box-shadow: 0 8px 20px rgba(46, 196, 182, 0.2);
                }

            /* Bottom Account Section */
            .sidebar-footer {
                margin-top: auto;
                padding-top: 20px;
                border-top: 1px solid #f1f5f9;
            }

            .btn-sidebar-logout {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 14px;
                background-color: #f1f5f9;
                color: #334155;
                font-weight: 600;
                border: none;
                padding: 12px 16px;
                border-radius: 12px;
                transition: all 0.2s ease;
                text-align: left;
            }

                .btn-sidebar-logout:hover {
                    background-color: #fee2e2;
                    color: #dc2626;
                }

            /* Main Floating Dashboard Context Right Area */
            .main-workspace-container {
                flex-grow: 1;
                margin-left: 260px; /* Accounts for fixed sidebar width */
                padding: 40px;
                width: calc(100% - 260px);
            }

            @@media (max-width: 992px) {
                body {
                    flex-direction: column;
                }

                .sidebar-wrapper {
                    width: 100%;
                    position: relative;
                    height: auto;
                    padding: 16px;
                }

                .main-workspace-container {
                    margin-left: 0;
                    width: 100%;
                    padding: 20px;
                }

                .sidebar-brand-container {
                    margin-bottom: 16px;
                }

                .menu-section-label {
                    margin-top: 12px;
                }
            }
    </style>
</head>
<body>

    <aside class="sidebar-wrapper">
        <a class="sidebar-brand-container" href="/Patient/Dashboard">
            <div class="brand-logo-icon">
                <i class="bi bi-heart-pulse-fill"></i>
            </div>
            <span class="brand-text">VirtualDerm</span>
        </a>

        <div class="menu-section-label">Main</div>
        <div class="sidebar-nav-links">
            <a class="sidebar-nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Patient/Dashboard" ? "active" : "")" href="/Patient/Dashboard">
                <i class="fa-solid fa-chart-pie"></i> Dashboard
            </a>
        </div>

        <div class="menu-section-label">Management</div>
        <div class="sidebar-nav-links">
            <a class="sidebar-nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Patient/Appointments" ? "active" : "")" href="/Patient/Appointments">
                <i class="fa-regular fa-calendar"></i> Appointments
            </a>
            <a class="sidebar-nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Patient/Consultations" ? "active" : "")" href="/Patient/Consultations">
                <i class="fa-regular fa-file-lines"></i> Consultations
            </a>
            <a class="sidebar-nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Patient/AIAssistant" ? "active" : "")" href="/Patient/AIAssistant">
                <i class="fa-solid fa-robot"></i> AI Assistant
            </a>
        </div>

        <div class="menu-section-label">Account</div>
        <div class="sidebar-nav-links">
            <a class="sidebar-nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Patient/Profile" ? "active" : "")" href="/Patient/Profile">
                <i class="fa-regular fa-user"></i> Profile
            </a>
        </div>

        <div class="sidebar-footer">
            @if (SignInManager.IsSignedIn(User))
            {
                <form method="post" action="/Auth/Logout">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn-sidebar-logout">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i>
                        Logout
                    </button>
                </form>
            }
            else
            {
                <a class="btn-sidebar-logout text-decoration-none" href="/Auth/Login">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    Login
                </a>
            }
        </div>
    </aside>

    <div class="main-workspace-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>