<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VirtualDerm</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f6fbfa;
            color: #0f172a;
        }

        /* SIDEBAR */

            .sidebar {
                position: fixed;
                left: 0;
                top: 0;
                width: 270px;
                height: 100vh;
                background: white;
                border-right: 1px solid #edf2f7;
                padding: 24px 18px;
                display: flex;
                flex-direction: column;
                z-index: 1000;
                overflow-y: auto;
                overflow-x: hidden;
            }

                .sidebar::-webkit-scrollbar {
                    width: 6px;
                }

                .sidebar::-webkit-scrollbar-thumb {
                    background: #d1d5db;
                    border-radius: 10px;
                }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 40px;
        }

        .brand-icon {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            background: linear-gradient(135deg, #20c7b6, #7ce3d8);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .brand h3 {
            font-size: 1.7rem;
            font-weight: 700;
            margin: 0;
            color: #14b8a6;
        }

        .brand p {
            margin: 0;
            color: #94a3b8;
            font-size: 0.88rem;
        }

        .nav-title {
            color: #94a3b8;
            font-size: 0.78rem;
            font-weight: 700;
            margin: 22px 14px 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            text-decoration: none;
            color: #475569;
            border-radius: 18px;
            margin-bottom: 8px;
            transition: 0.2s;
            font-weight: 500;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: linear-gradient(135deg, #20c7b6, #5dd9cb);
            color: white;
            box-shadow: 0 10px 25px rgba(32,199,182,0.25);
        }

        .sidebar i {
            width: 18px;
        }

        .logout-btn {
            margin-top: auto;
            background: #f8fafc;
        }

        /* MAIN */

        .main-content {
            margin-left: 270px;
            min-height: 100vh;
        }

        /* TOPBAR */

        .topbar {
            background: white;
            border-bottom: 1px solid #edf2f7;
            padding: 18px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .search-box {
            width: 520px;
            position: relative;
        }

        .search-box input {
            width: 100%;
            border: none;
            background: #f8fafc;
            border-radius: 18px;
            padding: 16px 18px 16px 48px;
            outline: none;
            font-size: 0.95rem;
        }

        .search-box i {
            position: absolute;
            left: 18px;
            top: 18px;
            color: #94a3b8;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .top-icon {
            width: 50px;
            height: 50px;
            border-radius: 16px;
            border: 1px solid #edf2f7;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            font-size: 1.1rem;
            background: white;
        }

        .profile-box {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 14px;
            border: 1px solid #edf2f7;
            border-radius: 18px;
            background: white;
        }

        .profile-avatar {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg, #20c7b6, #7ce3d8);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.2rem;
        }

        .profile-name {
            font-weight: 700;
            font-size: 1rem;
        }

        .profile-role {
            color: #94a3b8;
            font-size: 0.82rem;
        }

        .page-content {
            padding: 32px;
        }

        /* TABLE DESIGN */
.table-modern {
    background: #ffffff;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid #edf2f7;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
}

.table-modern table {
    margin-bottom: 0;
}

.table-modern thead {
    background: #f8fafc;
}

.table-modern th {
    padding: 18px 20px;
    font-size: 14px;
    font-weight: 700;
    color: #0f172a;
    border: none;
}

.table-modern td {
    padding: 18px 20px;
    border-top: 1px solid #f1f5f9;
    color: #475569;
    vertical-align: middle;
}

.table-modern tr:hover {
    background: #f8fffe;
}

.barangay-badge {
    background: rgba(32, 199, 182, 0.12);
    color: #14b8a6;
    padding: 6px 14px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 600;
    display: inline-block;
}

    </style>
</head>
<body>

    <!-- SIDEBAR -->

    <div class="sidebar">

        <div class="brand">

            <div class="brand-icon">
                <i class="fa-solid fa-stethoscope"></i>
            </div>

            <div>
                <h3>VitualDerm</h3>
            </div>

        </div>

        <div class="nav-title">Main</div>

        <a href="/" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
            <i class="fa-solid fa-table-columns"></i>
            Dashboard
        </a>

        <div class="nav-title">Management</div>

        <a href="/Patients" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patients" ? "active" : "")">
            <i class="fa-regular fa-user"></i>
            Patients
        </a>

        <a href="/Appointments" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointments" ? "active" : "")">
            <i class="fa-regular fa-calendar"></i>
            Appointments
        </a>

        <a href="/Consultations" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Consultations" ? "active" : "")">
            <i class="fa-regular fa-clipboard"></i>
            Consultations
        </a>

        <a href="/ChatSessions" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "ChatSessions" ? "active" : "")">
            <i class="fa-regular fa-comments"></i>
            Chat Sessions
        </a>

        <div class="nav-title">Account</div>

        <a href="/Profile">
            <i class="fa-regular fa-user"></i>
            Profile
        </a>

        <a href="#">
            <i class="fa-solid fa-gear"></i>
            Settings
        </a>

        <div class="nav-title">System</div>

        <a href="#">
            <i class="fa-solid fa-users"></i>
            Users
        </a>

        <a href="#">
            <i class="fa-regular fa-file-lines"></i>
            Reports
        </a>

        <a href="/Identity/Account/Login" class="logout-btn">
            <i class="fa-solid fa-right-from-bracket"></i>
            Logout
        </a>

    </div>

    <!-- MAIN -->

    <div class="main-content">

        <!-- TOPBAR -->

        <div class="topbar">

            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>

                <input type="text"
                       placeholder="Search patients, appointments..." />
            </div>

            <div class="topbar-right">

                <div class="top-icon">
                    <i class="fa-regular fa-bell"></i>
                </div>

                <div class="top-icon">
                    <i class="fa-regular fa-envelope"></i>
                </div>

                <div class="profile-box">

                    <div class="profile-avatar">
                        A
                    </div>

                    <div>
                        <div class="profile-name">
                            Administrator
                        </div>

                        <div class="profile-role">
                        </div>
                    </div>

                </div>

            </div>

        </div>

        <div class="page-content">
            @RenderBody()
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>