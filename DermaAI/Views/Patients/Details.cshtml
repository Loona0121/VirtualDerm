@model DermaAI.Models.Patient

@{
    ViewData["Title"] = "Patient Details";
}

<style>
    .details-card {
        background: white;
        border-radius: 24px;
        padding: 36px;
        max-width: 850px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    }

    .page-title {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 28px;
        color: #0f172a;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 18px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .detail-label {
        color: #64748b;
        font-weight: 600;
    }

    .detail-value {
        color: #0f172a;
        font-weight: 600;
    }

    .edit-btn {
        display: inline-block;
        margin-top: 28px;
        background: linear-gradient(135deg, #20c7b3, #58d5c9);
        color: white;
        padding: 12px 22px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 600;
    }

    .back-link {
        margin-left: 12px;
        text-decoration: none;
        color: #64748b;
        font-weight: 600;
    }
</style>

<div class="page-title">
    Patient Details
</div>

<div class="details-card">

    <div class="detail-row">
        <div class="detail-label">Full Name</div>
        <div class="detail-value">@Model.FullName</div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Age</div>
        <div class="detail-value">@Model.Age</div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Sex</div>
        <div class="detail-value">@Model.Sex</div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Address</div>
        <div class="detail-value">@Model.Address</div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Contact Number</div>
        <div class="detail-value">@Model.ContactNumber</div>
    </div>

    <div class="detail-row">
        <div class="detail-label">Created At</div>
        <div class="detail-value">@Model.CreatedAt</div>
    </div>

    <a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="edit-btn">
        Edit Patient
    </a>

    <a asp-action="Index" class="back-link">
        Back
    </a>

</div>