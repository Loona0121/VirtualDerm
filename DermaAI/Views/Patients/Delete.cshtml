@model DermaAI.Models.Patient

@{
    ViewData["Title"] = "Delete Patient";
}

<style>
    .delete-card {
        background: white;
        border-radius: 24px;
        padding: 36px;
        max-width: 750px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    }

    .page-title {
        font-size: 3rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .warning-text {
        font-size: 1.1rem;
        color: #dc2626;
        font-weight: 600;
        margin-bottom: 30px;
    }

    .info-row {
        display: flex;
        margin-bottom: 22px;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 12px;
    }

    .info-label {
        width: 180px;
        font-weight: 700;
        color: #334155;
    }

    .info-value {
        color: #0f172a;
    }

    .delete-btn {
        background: #ef4444;
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 600;
        margin-top: 20px;
    }

    .delete-btn:hover {
        background: #dc2626;
    }

    .cancel-link {
        margin-left: 14px;
        text-decoration: none;
        color: #64748b;
        font-weight: 600;
    }
</style>

<div class="page-title">
    Delete Patient
</div>

<div class="delete-card">

    <div class="warning-text">
        Are you sure you want to delete this patient?
    </div>

    <div class="info-row">
        <div class="info-label">Full Name</div>
        <div class="info-value">@Model.FullName</div>
    </div>

    <div class="info-row">
        <div class="info-label">Age</div>
        <div class="info-value">@Model.Age</div>
    </div>

    <div class="info-row">
        <div class="info-label">Sex</div>
        <div class="info-value">@Model.Sex</div>
    </div>

    <div class="info-row">
        <div class="info-label">Address</div>
        <div class="info-value">@Model.Address</div>
    </div>

    <div class="info-row">
        <div class="info-label">Contact Number</div>
        <div class="info-value">@Model.ContactNumber</div>
    </div>

    <form asp-action="Delete">

        <input type="hidden" asp-for="Id" />

        <button type="submit" class="delete-btn">
            Delete Patient
        </button>

        <a asp-action="Index" class="cancel-link">
            Cancel
        </a>

    </form>

</div>