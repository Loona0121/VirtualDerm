@model List<DermaAI.Models.Appointment>
@{
    ViewData["Title"] = "Appointments";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<style>
    /* PAGE HEADER */
    .page-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .page-header-custom h2 {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
            line-height: 1.2;
        }

        .page-header-custom p {
            color: #94a3b8;
            font-size: 0.9rem;
            margin: 0;
        }

    /* SUCCESS ALERT */
    .success-alert {
        background: #dcfce7;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: 18px;
        padding: 15px 18px;
        font-size: 0.9rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
    }

    /* FILTER BAR */
    .filter-bar {
        background: white;
        border: 1px solid #edf2f7;
        border-radius: 24px;
        padding: 22px;
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: end;
        margin-bottom: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .filter-label {
        font-size: 0.72rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .filter-input {
        height: 46px;
        min-width: 200px;
        border-radius: 14px;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        padding: 0 14px;
        font-size: 0.88rem;
        color: #0f172a;
        transition: 0.2s;
        outline: none;
    }

        .filter-input:focus {
            border-color: #20c7b6;
            background: white;
            box-shadow: 0 0 0 4px rgba(32,199,182,0.08);
        }

    .clear-btn {
        height: 46px;
        padding: 0 18px;
        border: none;
        border-radius: 14px;
        background: #f1f5f9;
        color: #475569;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

        .clear-btn:hover {
            background: #e2e8f0;
        }

    /* RESULT TEXT */
    .result-count {
        margin-bottom: 14px;
        color: #64748b;
        font-size: 0.88rem;
        font-weight: 500;
    }

    /* TABLE WRAPPER */
    .table-modern {
        background: white;
        border-radius: 26px;
        border: 1px solid #edf2f7;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }

    /* SECTION LABEL */
    .section-label {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 18px 24px 12px;
        font-size: 0.74rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .count-badge {
        background: rgba(20,184,166,0.12);
        color: #14b8a6;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    /* TABLE */
    .table-custom {
        width: 100%;
        border-collapse: collapse;
    }

        .table-custom thead th {
            background: #fcfcfd;
            padding: 18px 24px;
            border-bottom: 1px solid #f1f5f9;
            color: #94a3b8;
            font-size: 0.76rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            text-align: left;
        }

        .table-custom tbody td {
            padding: 20px 24px;
            border-bottom: 1px solid #f8fafc;
            font-size: 0.9rem;
            color: #334155;
            vertical-align: middle;
        }

        .table-custom tbody tr:last-child td {
            border-bottom: none;
        }

        .table-custom tbody tr:hover {
            background: #fafafa;
        }

    /* PATIENT */
    .patient-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .patient-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg,#2dd4bf,#60a5fa);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.92rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .patient-name {
        font-weight: 600;
        color: #0f172a;
    }

    /* STATUS badges (matching your working dashboard names) */
    .status {
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
    }

    .confirmed {
        background: #dcfce7;
        color: #16a34a;
    }

    .pending {
        background: #fef3c7;
        color: #d97706;
    }

    .cancelled {
        background: #fee2e2;
        color: #dc2626;
    }

    .done {
        background: #e0f2fe;
        color: #0ea5e9;
    }

    /* ACTION BUTTONS */
    .actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .action-btn {
        height: 38px;
        padding: 0 15px;
        border: none;
        border-radius: 12px;
        font-size: 0.78rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-confirm {
        background: #dcfce7;
        color: #16a34a;
    }

        .btn-confirm:hover {
            background: #16a34a;
            color: white;
        }

    .btn-cancel {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-cancel:hover {
            background: #dc2626;
            color: white;
        }

    /* EMPTY STATE */
    .empty-state {
        text-align: center;
        color: #94a3b8;
        padding: 48px 0;
        font-size: 0.9rem;
    }
</style>

<div class="page-header-custom">
    <div>
        <h2>Appointments</h2>
        <p>Manage and update patient appointments</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="success-alert">
        <i class="fa-solid fa-circle-check"></i>
        @TempData["Success"]
    </div>
}

<div class="filter-bar">
    <div class="filter-group">
        <div class="filter-label">Search</div>
        <input type="text" id="searchInput" class="filter-input" placeholder="Patient or doctor name..." style="width:220px;" oninput="filterTable()" />
    </div>
    <div class="filter-group">
        <div class="filter-label">Status</div>
        <select id="statusFilter" class="filter-input" style="width:150px;" onchange="filterTable()">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Cancelled">Cancelled</option>
            <option value="Done">Done</option>
        </select>
    </div>
    <button class="clear-btn" onclick="clearFilters()">Clear</button>
</div>

<div class="result-count" id="resultCount">@Model.Count appointment(s) found</div>

<div class="table-modern">
    <div class="section-label">
        All Appointments <span class="count-badge">@Model.Count</span>
    </div>
    <table class="table-custom" id="appointmentsTable">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Doctor</th>
                <th>Date & Time</th>
                <th>Status</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var a in Model)
                {
                    <tr>
                        <td>
                            <div class="patient-info">
                                <div class="patient-avatar">
                                    @(a.Patient?.FullName?.Substring(0, 1).ToUpper() ?? "P")
                                </div>
                                <div class="patient-name">@a.Patient?.FullName</div>
                            </div>
                        </td>
                        <td>@a.DoctorId</td>
                        <td>@a.ScheduledDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                        <td><span class="status @a.Status?.ToLower()">@a.Status</span></td>
                        <td>@(a.Notes ?? "—")</td>
                        <td>
                            <div class="actions">
                                @if (a.Status != "Confirmed" && a.Status != "Cancelled" && a.Status != "Done")
                                {
                                    <form method="post" action="/Staff/UpdateAppointmentStatus" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="appointmentId" value="@a.Id" />
                                        <input type="hidden" name="status" value="Confirmed" />
                                        <button type="submit" class="action-btn btn-confirm">
                                            <i class="fa-solid fa-check"></i> Confirm
                                        </button>
                                    </form>
                                }
                                @if (a.Status != "Cancelled" && a.Status != "Done")
                                {
                                    <form method="post" action="/Staff/UpdateAppointmentStatus" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="appointmentId" value="@a.Id" />
                                        <input type="hidden" name="status" value="Cancelled" />
                                        <button type="submit" class="action-btn btn-cancel"
                                                onclick="return confirm('Cancel this appointment?')">
                                            <i class="fa-solid fa-xmark"></i> Cancel
                                        </button>
                                    </form>
                                }
                                @if (a.Status == "Cancelled" || a.Status == "Done")
                                {
                                    <span style="color:#94a3b8; font-size:0.78rem; font-style:italic;">No actions</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state">No appointments found.</div></td></tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const status = document.getElementById('statusFilter').value.toLowerCase();
            const rows = document.querySelectorAll('#appointmentsTable tbody tr');
            let count = 0;

            rows.forEach(row => {
                const name = row.cells[0]?.textContent.toLowerCase() ?? '';
                const doctor = row.cells[1]?.textContent.toLowerCase() ?? '';
                const rowStatus = row.cells[3]?.textContent.trim().toLowerCase() ?? '';
                const matchSearch = name.includes(search) || doctor.includes(search);
                const matchStatus = status === '' || rowStatus === status;
                const match = matchSearch && matchStatus;
                row.style.display = match ? '' : 'none';
                if (match) count++;
            });

            document.getElementById('resultCount').textContent = count + ' appointment(s) found';
        }

        function clearFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('statusFilter').value = '';
            filterTable();
        }
    </script>
}