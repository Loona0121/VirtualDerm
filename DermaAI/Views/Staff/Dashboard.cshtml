@{
    ViewData["Title"] = "Staff Dashboard";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }

    .dashboard-title h2 {
        font-size: 2.1rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 5px;
    }

    .dashboard-title p {
        color: #94a3b8;
        margin: 0;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        border: 1px solid #edf2f7;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 18px;
        font-size: 1.2rem;
    }

    .green {
        background: rgba(32,199,182,0.12);
        color: #20c7b6;
    }

    .blue {
        background: rgba(59,130,246,0.12);
        color: #3b82f6;
    }

    .purple {
        background: rgba(168,85,247,0.12);
        color: #a855f7;
    }

    .stat-title {
        color: #94a3b8;
        font-size: 0.82rem;
        margin-bottom: 6px;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .stat-note {
        color: #94a3b8;
        font-size: 0.78rem;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
        margin-top: 24px;
    }

    .dashboard-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        border: 1px solid #edf2f7;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }

    .card-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
    }

        .card-header-custom h5 {
            font-weight: 700;
            margin: 0;
        }

    .appointment-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .appointment-item:last-child {
            border-bottom: none;
        }

    .appointment-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .appointment-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2dd4bf, #60a5fa);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .status {
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .confirmed {
        background: #dcfce7;
        color: #16a34a;
    }

    .pending {
        background: #fef3c7;
        color: #d97706;
    }

    .cancelled {
        background: #fee2e2;
        color: #dc2626;
    }

    .done {
        background: #e0f2fe;
        color: #0ea5e9;
    }

    .empty-state {
        color: #94a3b8;
        text-align: center;
        padding: 24px 0;
        font-size: 0.88rem;
    }

    .quick-action {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px;
        background: #f8fafc;
        border-radius: 16px;
        text-decoration: none;
        color: #0f172a;
        font-weight: 600;
        transition: 0.2s;
        margin-bottom: 12px;
    }

        .quick-action:hover {
            background: linear-gradient(135deg, #20c7b6, #5dd9cb);
            color: white;
            box-shadow: 0 8px 20px rgba(32,199,182,0.25);
        }

            .quick-action:hover .qa-icon {
                background: rgba(255,255,255,0.2);
                color: white;
            }

    .qa-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: rgba(32,199,182,0.12);
        color: #20c7b6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }
</style>

<div class="dashboard-header">
    <div class="dashboard-title">
        <h2>Dashboard</h2>
        <p>Welcome back! Here's what's happening today.</p>
    </div>
    <a href="/Staff/CreateConsultation"
       style="background:linear-gradient(135deg,#20c7b6,#5dd9cb); color:white; border:none; border-radius:16px; padding:14px 24px; font-weight:600; text-decoration:none; display:flex; align-items:center; gap:10px;">
        <i class="fa-solid fa-plus"></i> New Consultation
    </a>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-users"></i></div>
        <div class="stat-title">Total Patients</div>
        <div class="stat-number">@ViewBag.TotalPatients</div>
        <div class="stat-note">Registered in system</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-regular fa-calendar"></i></div>
        <div class="stat-title">Appointments</div>
        <div class="stat-number">@ViewBag.TotalAppointments</div>
        <div class="stat-note">Total scheduled</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fa-regular fa-clipboard"></i></div>
        <div class="stat-title">Consultations</div>
        <div class="stat-number">@ViewBag.TotalConsultations</div>
        <div class="stat-note">Doctor notes recorded</div>
    </div>
</div>

<div class="dashboard-grid">
    <div>
        <div class="dashboard-card mb-4">
            <div class="card-header-custom">
                <h5>Recent Consultations</h5>
                <a href="/Staff/Consultations" class="btn btn-sm btn-light">View All</a>
            </div>
            @{
                var recentConsultations = ViewBag.RecentConsultations as List<DermaAI.Models.Consultation>;
            }
            @if (recentConsultations != null && recentConsultations.Any())
            {
                <table style="width:100%;">
                    <thead>
                        <tr>
                            <th style="color:#94a3b8; font-size:0.82rem; padding-bottom:12px;">Patient</th>
                            <th style="color:#94a3b8; font-size:0.82rem; padding-bottom:12px;">Diagnosis</th>
                            <th style="color:#94a3b8; font-size:0.82rem; padding-bottom:12px;">Notes</th>
                            <th style="color:#94a3b8; font-size:0.82rem; padding-bottom:12px;">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in recentConsultations)
                        {
                            <tr>
                                <td style="padding:14px 0; border-top:1px solid #f1f5f9;">
                                    <strong>@c.Appointment?.Patient?.FullName</strong>
                                </td>
                                <td style="padding:14px 0; border-top:1px solid #f1f5f9; font-size:0.88rem;">
                                    @(c.Diagnosis ?? "—")
                                </td>
                                <td style="padding:14px 0; border-top:1px solid #f1f5f9; font-size:0.88rem;">
                                    @(c.DoctorNotes?.Length > 30 ? c.DoctorNotes.Substring(0, 30) + "..." : c.DoctorNotes)
                                </td>
                                <td style="padding:14px 0; border-top:1px solid #f1f5f9; font-size:0.88rem;">
                                    @c.CreatedAt.ToString("MMM dd, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">No consultations yet.</div>
            }
        </div>

        <div class="dashboard-card">
            <div class="card-header-custom">
                <h5>Upcoming Appointments</h5>
                <a href="/Staff/Appointments" class="btn btn-sm btn-light">View All</a>
            </div>
            @{
                var upcomingAppointments = ViewBag.UpcomingAppointments as List<DermaAI.Models.Appointment>;
            }
            @if (upcomingAppointments != null && upcomingAppointments.Any())
            {
                @foreach (var a in upcomingAppointments)
                {
                    <div class="appointment-item">
                        <div class="appointment-left">
                            <div class="appointment-avatar">
                                @(a.Patient?.FullName?.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <strong>@a.Patient?.FullName</strong><br />
                                <small class="text-muted">@a.ScheduledDate.ToString("MMM dd, yyyy hh:mm tt")</small>
                            </div>
                        </div>
                        <span class="status @a.Status?.ToLower()">@a.Status</span>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">No upcoming appointments.</div>
            }
        </div>
    </div>

    <div>
        <div class="dashboard-card">
            <div class="card-header-custom">
                <h5>Quick Actions</h5>
            </div>
            <a href="/Staff/Appointments" class="quick-action">
                <div class="qa-icon"><i class="fa-regular fa-calendar"></i></div>
                View Appointments
            </a>
            <a href="/Staff/CreateConsultation" class="quick-action">
                <div class="qa-icon"><i class="fa-solid fa-plus"></i></div>
                New Consultation
            </a>
            <a href="/Staff/Patients" class="quick-action">
                <div class="qa-icon"><i class="fa-regular fa-user"></i></div>
                View Patients
            </a>
            <a href="/Staff/AIAssistant" class="quick-action">
                <div class="qa-icon"><i class="fa-solid fa-robot"></i></div>
                AI Assistant
            </a>
        </div>
    </div>
</div>