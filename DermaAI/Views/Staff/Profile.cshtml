@model DermaAI.Models.ApplicationUser
@{
    ViewData["Title"] = "Profile";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<style>
    .profile-card {
        background:white; border-radius:24px; padding:36px;
        border:1px solid #edf2f7; box-shadow:0 10px 30px rgba(0,0,0,0.04);
        max-width:700px;
    }
    .avatar-section { display:flex; align-items:center; gap:24px; margin-bottom:28px; }
    .avatar-wrap { position:relative; }
    .profile-avatar-large {
        width:90px; height:90px; border-radius:50%;
        background:linear-gradient(135deg,#2dd4bf,#60a5fa);
        color:white; display:flex; align-items:center;
        justify-content:center; font-weight:700; font-size:2rem; overflow:hidden;
    }
    .profile-avatar-large img { width:100%; height:100%; object-fit:cover; }
    .avatar-upload-btn {
        position:absolute; bottom:0; right:0;
        width:28px; height:28px; border-radius:50%;
        background:linear-gradient(135deg,#2dd4bf,#14b8a6);
        color:white; border:2px solid white;
        display:flex; align-items:center; justify-content:center;
        font-size:0.7rem; cursor:pointer; transition:0.2s;
    }
    .avatar-upload-btn:hover { transform:scale(1.1); }
    .form-label { font-weight:600; color:#0f172a; font-size:0.88rem; }
    .form-control-custom {
        height:48px; border-radius:12px; border:1.5px solid #e2e8f0;
        padding:0 16px; font-size:0.92rem; background:#f8fafc; width:100%; transition:0.2s;
    }
    .form-control-custom:focus {
        border-color:#14b8a6; box-shadow:0 0 0 3px rgba(20,184,166,0.12);
        outline:none; background:white;
    }
    .save-btn {
        background:linear-gradient(135deg,#2dd4bf,#14b8a6);
        color:white; border:none; border-radius:12px;
        padding:12px 28px; font-weight:700; cursor:pointer; transition:0.2s;
    }
    .save-btn:hover { transform:translateY(-2px); }
    .role-badge {
        background:rgba(20,184,166,0.12); color:#14b8a6;
        padding:6px 16px; border-radius:999px; font-size:0.82rem; font-weight:700;
    }
</style>

<div style="margin-bottom:28px;">
    <h2 style="font-size:2.1rem; font-weight:700; color:#0f172a; margin-bottom:5px;">Profile</h2>
    <p style="color:#94a3b8; margin:0;">Manage your personal information</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#dcfce7; color:#16a34a; padding:14px 20px; border-radius:14px; margin-bottom:20px; font-weight:600;">
        <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
    </div>
}

<div class="profile-card">
    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="avatar-section">
            <div class="avatar-wrap">
                <div class="profile-avatar-large" id="avatarPreview">
                    @if (!string.IsNullOrEmpty(Model?.ProfilePhoto))
                    {
                        <img src="@Model.ProfilePhoto" />
                    }
                    else
                    {
                        <span>@(Model?.FullName?.Substring(0, 1).ToUpper() ?? "S")</span>
                    }
                </div>
                <label for="photoInput" class="avatar-upload-btn" title="Change photo">
                    <i class="fa-solid fa-camera"></i>
                </label>
                <input type="file" id="photoInput" name="ProfilePhoto" accept="image/*"
                       style="display:none;" onchange="previewPhoto(this)" />
            </div>
            <div>
                <div style="font-weight:700; font-size:1.1rem; color:#0f172a; margin-bottom:6px;">@Model?.FullName</div>
                <div style="margin-bottom:8px;"><span class="role-badge">Staff</span></div>
                <div style="font-size:0.82rem; color:#94a3b8;">Click the camera icon to change your photo</div>
            </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;">
            <div>
                <label class="form-label">Full Name</label>
                <input name="FullName" value="@Model?.FullName" class="form-control-custom" placeholder="Enter full name" />
            </div>
            <div>
                <label class="form-label">Email Address</label>
                <input value="@Model?.Email" class="form-control-custom" disabled style="opacity:0.6;" />
            </div>
            <div>
                <label class="form-label">Phone Number</label>
                <input name="PhoneNumber" value="@Model?.PhoneNumber" class="form-control-custom" placeholder="Enter phone number" />
            </div>
            <div>
                <label class="form-label">Role</label>
                <input value="Staff" class="form-control-custom" disabled style="opacity:0.6;" />
            </div>
        </div>

        <button type="submit" class="save-btn">
            <i class="fa-solid fa-floppy-disk"></i> Save Changes
        </button>
    </form>
</div>

<script>
    function previewPhoto(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('avatarPreview').innerHTML =
                    `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;" />`;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>