@model DermaAI.Models.Appointment

@{
    ViewData["Title"] = "Delete Appointment";
    var initials = string.Join("", (Model.Patient?.FullName ?? "?")
        .Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()));
}

<style>
    .page-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 6px;
        color: #0f172a;
    }

    .delete-card {
        background: white;
        border-radius: 24px;
        padding: 36px;
        max-width: 550px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        border: 1px solid #fee2e2;
    }

    .warning-icon {
        font-size: 3rem;
        margin-bottom: 16px;
    }

    .warning-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .warning-sub {
        color: #94a3b8;
        font-size: 0.88rem;
        margin-bottom: 24px;
    }

    .patient-preview {
        background: #f8fafc;
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, #20c7b6, #7ce3d8);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
    }

    .preview-name {
        font-weight: 700;
        color: #0f172a;
    }

    .preview-sub {
        color: #94a3b8;
        font-size: 0.82rem;
    }

    .delete-btn {
        background: #e11d48;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.9rem;
    }

    .cancel-btn {
        background: #f1f5f9;
        color: #64748b;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        margin-left: 12px;
    }
</style>

<div class="page-title">Delete Appointment</div>
<p style="color:#94a3b8; font-size:0.88rem; margin-bottom:24px;">This action cannot be undone</p>

<div class="delete-card">
    <div class="warning-icon">⚠️</div>
    <div class="warning-title">Are you sure you want to delete this appointment?</div>
    <div class="warning-sub">This will permanently remove the appointment from the system.</div>

    <div class="patient-preview">
        <div class="avatar">@initials</div>
        <div>
            <div class="preview-name">@Model.Patient?.FullName</div>
            <div class="preview-sub">
                Dr. @Model.DoctorId · @Model.ScheduledDate.ToString("MMM dd, yyyy hh:mm tt")
            </div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="delete-btn">Delete</button>
        <a asp-action="Index" class="cancel-btn">Cancel</a>
    </form>
</div>