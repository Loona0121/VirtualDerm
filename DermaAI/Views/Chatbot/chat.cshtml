@model DermaAI.Models.ChatSession

@{
    ViewData["Title"] = "Chat - DermaAI";
}

<div class="container mt-4">
    <h4>🤖 DermaAI Chat — @Model.Patient?.FullName</h4>
    <p class="text-muted">Session started: @Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</p>

    <!-- Chat Messages -->
    <div class="card mb-3" style="height:450px; overflow-y:auto;" id="chatBox">
        <div class="card-body">
            @foreach (var message in Model.ChatMessages.OrderBy(m => m.SentAt))
            {
                if (message.Role == "user")
                {
                    <div class="d-flex justify-content-end mb-3">
                        <div class="bg-primary text-white p-3 rounded" style="max-width:70%">
                            <small class="d-block mb-1">You</small>
                            @message.Content
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-content-start mb-3">
                        <div class="bg-light p-3 rounded border" style="max-width:70%">
                            <small class="d-block mb-1 text-primary">🤖 DermaAI</small>
                            @message.Content
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Send Message Form -->
    <div class="card">
        <div class="card-body">
            <form method="post" action="/Chatbot/SendMessage">
                <input type="hidden" name="sessionId" value="@Model.Id" />
                <div class="input-group">
                    <input type="text" name="message" class="form-control"
                        placeholder="Type your follow-up question..." required />
                    <button type="submit" class="btn btn-primary">Send 💬</button>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Appointments" asp-action="Create" class="btn btn-success">
            📅 Book Appointment with Doctor
        </a>
        <a asp-controller="Chatbot" asp-action="Index" class="btn btn-outline-secondary ms-2">
            Start New Chat
        </a>
    </div>
</div>

<script>
    // Auto scroll to bottom of chat
    var chatBox = document.getElementById('chatBox');
    chatBox.scrollTop = chatBox.scrollHeight;
</script>